{
  "name": "@mortenbroesby/astrograph",
  "version": "0.2.2-alpha.63",
  "type": "module",
  "license": "MIT",
  "description": "Local deterministic context engine for AI-assisted code exploration",
  "keywords": [
    "astrograph",
    "mcp",
    "code-indexing",
    "code-search",
    "local-first",
    "sqlite"
  ],
  "homepage": "https://github.com/mortenbroesby/astrograph",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mortenbroesby/astrograph.git"
  },
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "bugs": {
    "url": "https://github.com/mortenbroesby/astrograph/issues"
  },
  "engines": {
    "node": ">=24"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "astrograph": "dist/ai-context-engine.js",
    "ai-context-engine": "dist/ai-context-engine.js"
  },
  "files": [
    "README.md",
    "LICENSE",
    "assets/astrograph-logo.svg",
    "dist",
    "src/ai-context-engine.ts",
    "src/scripts/check-version-bump.ts",
    "src/scripts/git-smart-refresh.ts",
    "src/scripts/install.ts",
    "src/scripts/release-agent.ts",
    "src/scripts/run-vitest.ts",
    "src/scripts/smoke-package-bin.ts"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm run build:js && pnpm run build:workers && pnpm run build:types",
    "build:js": "tsup src/index.ts src/cli.ts src/mcp.ts src/ai-context-engine.ts --format esm --target node24 --out-dir dist --clean --tsconfig tsconfig.build.json",
    "build:workers": "tsup src/workers/analyze-file-worker.ts --format esm --target node24 --out-dir dist/workers --tsconfig tsconfig.build.json",
    "build:types": "tsc -p tsconfig.build.json",
    "cli": "node ./dist/cli.js",
    "mcp": "node --no-warnings ./dist/mcp.js",
    "git-refresh": "node --experimental-strip-types ./src/scripts/git-smart-refresh.ts",
    "dev:cli": "node --experimental-strip-types ./src/cli.ts",
    "dev:mcp": "node --no-warnings --experimental-strip-types ./src/mcp.ts",
    "bench:small": "node --experimental-strip-types ./scripts/benchmark-small.mjs",
    "bench:cli": "node --experimental-strip-types ./scripts/benchmark-cli.mjs",
    "bench:corpus": "node --experimental-strip-types ./bench/src/cli.ts",
    "bench:perf": "node --experimental-strip-types ./scripts/perf.mjs",
    "bench:perf:index": "node --experimental-strip-types ./scripts/perf-index.mjs",
    "bench:perf:query": "node --experimental-strip-types ./scripts/perf-query.mjs",
    "bench:perf:serialize": "node --experimental-strip-types ./scripts/perf-serialize.mjs",
    "profile:index:clinic": "clinic flame --dest .profiles/clinic/index --name astrograph-index -- node --experimental-strip-types ./scripts/perf-index.mjs",
    "profile:query:clinic": "clinic doctor --dest .profiles/clinic/query --name astrograph-query -- node --experimental-strip-types ./scripts/perf-query.mjs",
    "profile:index:0x": "0x --output-dir .profiles/0x/index -- node --experimental-strip-types ./scripts/perf-index.mjs",
    "profile:query:0x": "0x --output-dir .profiles/0x/query -- node --experimental-strip-types ./scripts/perf-query.mjs",
    "test:package-bin": "node --experimental-strip-types ./src/scripts/smoke-package-bin.ts",
    "check:version-bump": "node --experimental-strip-types ./src/scripts/check-version-bump.ts",
    "release:plan": "node --experimental-strip-types ./src/scripts/release-agent.ts",
    "release:apply": "node --experimental-strip-types ./src/scripts/release-agent.ts --apply",
    "type-lint": "pnpm run type-check && tsc -p ./bench/tsconfig.json --noEmit && tsc -p ./tsconfig.build.json --noEmit",
    "type-check": "tsc --noEmit",
    "test": "node --experimental-strip-types ./src/scripts/run-vitest.ts",
    "test:slow": "ASTROGRAPH_ENABLE_SLOW_TESTS=1 node --experimental-strip-types ./src/scripts/run-vitest.ts",
    "prepack": "pnpm run build"
  },
  "devDependencies": {
    "0x": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.1",
    "@types/picomatch": "^4.0.3",
    "clinic": "^13.0.0",
    "tinybench": "^6.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@clack/prompts": "^0.11.0",
    "cac": "^6.7.14",
    "@node-rs/xxhash": "^1.7.6",
    "@parcel/watcher": "^2.5.6",
    "@vscode/ripgrep": "^1.17.1",
    "better-sqlite3": "^12.9.0",
    "fast-json-stringify": "^6.3.0",
    "fdir": "^6.5.0",
    "oxc-parser": "^0.127.0",
    "oxc-resolver": "^11.19.1",
    "p-map": "^7.0.4",
    "picomatch": "^4.0.4",
    "pino": "^10.3.1",
    "piscina": "^5.1.4",
    "rxjs": "^7.8.2",
    "tiktoken": "^1.0.22",
    "tokenx": "^1.3.0",
    "tree-sitter": "0.21.1",
    "tree-sitter-javascript": "0.23.1",
    "tree-sitter-typescript": "0.23.2",
    "zod": "^4.3.6"
  },
  "packageManager": "pnpm@9.15.9"
}
